# FlowSight — environment for docker compose
# Copy to .env and edit:  cp .env.example .env
# All values are optional; sensible defaults are baked into docker-compose.yml.

# Timezone offset (hours from UTC) used for daily stats/reports. Thailand = 7
TZ_OFFSET=7

# Set to 1 to disable local camera engine (cloud/aggregator mode)
CLOUD_MODE=0

# AI Insight providers (optional). Leave blank to use the offline rule-based
# summary. Gemini is tried first, then Claude.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
