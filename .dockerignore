# Keep the build context small & free of secrets/binaries

# VCS / docs
.git
.gitignore
*.md

# Node — built inside the image's frontend stage from source, not copied from host
frontend/node_modules/
frontend/dist/

# Python caches
**/__pycache__/
*.pyc
*.pyo
*.log

# Real runtime data & configs — provided via volumes, never baked into the image
backend/data/
backend/config/zones_config.json
backend/config/behaviors_config.json
backend/config/brand_config.json

# Windows installer artifacts & launchers (not used in a Linux container)
scripts/installer/
scripts/installer_output/
scripts/*.bat

# Host-only dependency list (container uses requirements-docker.txt)
requirements.txt

# macOS noise
._*
.DS_Store
